{
  "manifest_version": 3,
  "name": "Crunchyroll Polish AI Subtitles",
  "version": "1.0.0",
  "description": "Free AI-powered Polish subtitles for Crunchyroll anime using local models. No subscriptions, no cloud, completely offline.",
  "author": "Open Source Contributors",
  "homepage_url": "https://github.com/zareb343442/crunchyroll-polish-subtitles",
  "icons": {
    "16": "assets/icon-16.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "permissions": [
    "tabCapture",
    "scripting",
    "webRequest",
    "storage",
    "offscreen",
    "activeTab"
  ],
  "host_permissions": [
    "https://www.crunchyroll.com/*",
    "https://crunchyroll.com/*"
  ],
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.crunchyroll.com/*",
        "https://crunchyroll.com/*"
      ],
      "js": ["dist/content-script.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "Polish AI Subtitles",
    "default_icon": {
      "16": "assets/icon-16.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": [
        "dist/subtitle-overlay.js",
        "dist/subtitle-styles.css",
        "assets/fonts/*"
      ],
      "matches": [
        "https://www.crunchyroll.com/*",
        "https://crunchyroll.com/*"
      ]
    }
  ]
}
